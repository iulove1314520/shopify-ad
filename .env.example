# 应用运行环境，可选值通常为 development / production
NODE_ENV=production
# API 服务监听端口
PORT=38417
# 允许跨域访问的来源列表，多个域名用英文逗号分隔；如果走同域反向代理可留空
CORS_ALLOW_ORIGINS=

# SQLite 数据库文件在容器内的存放路径
SQLITE_PATH=/app/data/app.db
# SQLite 遇到锁时的等待时间，单位毫秒
SQLITE_BUSY_TIMEOUT_MS=5000
# 访客数据保留天数，超期数据可清理
VISITOR_RETENTION_DAYS=7
# 订单、匹配、回传和 Webhook 记录的保留天数，超期后可一键清理
BUSINESS_DATA_RETENTION_DAYS=30
# 订单匹配的时间窗口，单位天
MATCH_WINDOW_DAYS=3
# 请求第三方平台 API 的超时时间，单位毫秒
REQUEST_TIMEOUT_MS=10000
# 单次回传流程内允许尝试的最大次数，包含第一次发送
CALLBACK_MAX_ATTEMPTS=2
# 回传失败且可重试时，两次尝试之间的等待时间，单位毫秒
CALLBACK_RETRY_DELAY_MS=800
# 访客上报接口的限流窗口，单位毫秒
VISITOR_RATE_LIMIT_WINDOW_MS=60000
# 访客上报接口在限流窗口内允许的最大请求数
VISITOR_RATE_LIMIT_MAX=90
# Shopify Webhook 接口的限流窗口，单位毫秒
WEBHOOK_RATE_LIMIT_WINDOW_MS=60000
# Shopify Webhook 接口在限流窗口内允许的最大请求数
WEBHOOK_RATE_LIMIT_MAX=120
# 手动重试接口的限流窗口，单位毫秒
RETRY_RATE_LIMIT_WINDOW_MS=60000
# 手动重试接口在限流窗口内允许的最大请求数
RETRY_RATE_LIMIT_MAX=10
# 一键清理旧数据接口的限流窗口，单位毫秒
CLEANUP_RATE_LIMIT_WINDOW_MS=3600000
# 一键清理旧数据接口在限流窗口内允许的最大请求数
CLEANUP_RATE_LIMIT_MAX=2
# 列表接口默认返回条数
DEFAULT_LIST_LIMIT=100
# 列表接口允许请求的最大条数
MAX_LIST_LIMIT=500

# 看板接口鉴权令牌，生产环境必须配置且不要使用默认值
API_AUTH_TOKEN=change_me
# Shopify Webhook 验签密钥
SHOPIFY_WEBHOOK_SECRET=replace_me

# TikTok Pixel ID；为空时，后台会把 TikTok 标记为“待补齐”
TIKTOK_PIXEL_ID=
# TikTok Access Token；为空时，后台会把 TikTok 标记为“待补齐”
TIKTOK_ACCESS_TOKEN=
# TikTok 事件回传接口地址
TIKTOK_API_URL=https://business-api.tiktok.com/open_api/v1.3/event/track/

# Facebook Pixel ID；为空时，后台会把 Facebook 标记为“待补齐”
FACEBOOK_PIXEL_ID=
# Facebook Access Token；为空时，后台会把 Facebook 标记为“待补齐”
FACEBOOK_ACCESS_TOKEN=
